# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
build/
dist/
.eggs/
.venv/
venv/
env/

# --- Jupyter ---
.ipynb_checkpoints/
*.ipynb_checkpoints

# --- Testing / coverage ---
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.mypy_cache/
.ruff_cache/

# --- IDEs ---
.vscode/
.idea/
*.swp
*.swo

# --- OS ---
.DS_Store
Thumbs.db

# --- Data: keep raw and interim out of git ---
data/raw/**
!data/raw/**/.gitkeep
data/interim/**
!data/interim/**/.gitkeep
data/processed/**
!data/processed/**/.gitkeep

# Project-local data (use data_refs.md to record sources instead)
projects/*/data/
*.csv
*.parquet
*.feather
*.h5
*.hdf5
*.pkl
*.pickle

# --- Secrets ---
.env
.env.local
*.key
secrets/

# --- Misc ---
*.log
